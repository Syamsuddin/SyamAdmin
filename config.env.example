# ============================================
# SyamAdmin Configuration
# ============================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_user_id

# --- Anthropic AI ---
ANTHROPIC_API_KEY=your_anthropic_api_key
# Model AI (opsional, default: claude-haiku-4-5-20251001)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Server Identity ---
SERVER_NAME=my-vps-01

# --- Self-Update (/update dari GitHub) ---
# Repo sumber & branch yang dipantau perintah /update (self-update SyamAdmin).
GITHUB_REPO=Syamsuddin/SyamAdmin
UPDATE_BRANCH=main
# Opsional: lokasi instalasi, nama service systemd, & file log updater (default aman).
# INSTALL_DIR=/opt/syamadmin
# SERVICE_NAME=syamadmin
# UPDATE_LOG=/var/log/syamadmin/update.log
SERVER_TIMEZONE=Asia/Makassar

# --- Monitoring Thresholds ---
ALERT_THRESHOLD_CPU=85
ALERT_THRESHOLD_RAM=90
ALERT_THRESHOLD_DISK=85
ALERT_THRESHOLD_LOAD=4.0
MONITOR_INTERVAL=60

# --- Security ---
SSH_PORT=22
ALLOWED_SSH_KEYS=

# --- Backup ---
BACKUP_DIR=/var/backups/syamadmin
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE=0 2 * * *

# --- MySQL ---
MYSQL_ROOT_PASSWORD=auto_generated_on_provision

# --- PHP Version ---
PHP_VERSION=8.3

# --- Logging ---
LOG_FILE=/var/log/syamadmin/agent.log
LOG_LEVEL=INFO

# --- Database ---
DB_PATH=/var/lib/syamadmin/syamadmin.db
# Retention (hari) — pemangkasan data lama otomatis untuk membatasi ukuran DB
METRICS_RETENTION_DAYS=30
AUDIT_RETENTION_DAYS=90
# Memory Core (Pilar 3 & 4)
CHAT_HISTORY_RETENTION_DAYS=14
LONG_TERM_MEMORY_MAX_ROWS=1000

# --- PeFi (Pre-Emptive Firewall Agent) ---
# Aktif/nonaktif & interval scan (detik)
PEFI_ENABLED=true
PEFI_INTERVAL=60
# Auto-block: bila true, IP dengan verdict BLOCK & confidence tinggi diblokir otomatis
PEFI_AUTO_BLOCK=false
PEFI_AUTO_BLOCK_CONFIDENCE=0.95
# Threshold deteksi anomali (rule-based)
PEFI_THRESHOLD_CONN_PER_MIN=200
PEFI_THRESHOLD_PORT_SCAN=10
PEFI_THRESHOLD_SYN=50
PEFI_THRESHOLD_SPIKE_MULTIPLIER=3.0
PEFI_THRESHOLD_SSH_FAIL=20
PEFI_THRESHOLD_HTTP_ERRORS=50
PEFI_BASELINE_MIN_SAMPLES=10
# Jaringan tepercaya tambahan (CIDR, dipisah koma) — tidak pernah diblokir
PEFI_TRUSTED_NETWORKS=
# Feedback loop: jumlah false-positive sebelum IP di-auto-whitelist
PEFI_FP_AUTO_WHITELIST_COUNT=3
# M-3: rate limit panggilan AI (detik) — cegah ribuan API call saat serangan panjang
PEFI_AI_COOLDOWN=300
# M-4: jalankan cleanup UFW rule expired + prune tiap N tick (bukan tiap tick)
PEFI_CLEANUP_EVERY_TICKS=10
# M-6: cooldown notifikasi per-IP (detik) — cegah banjir notifikasi dari IP yang sama
PEFI_NOTIF_COOLDOWN=1800
