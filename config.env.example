# ============================================
# SyamAdmin Configuration
# ============================================

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_user_id

# --- Anthropic AI ---
ANTHROPIC_API_KEY=your_anthropic_api_key
# Model AI (opsional, default: claude-haiku-4-5-20251001)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Server Identity ---
SERVER_NAME=my-vps-01
SERVER_TIMEZONE=Asia/Makassar

# --- Monitoring Thresholds ---
ALERT_THRESHOLD_CPU=85
ALERT_THRESHOLD_RAM=90
ALERT_THRESHOLD_DISK=85
ALERT_THRESHOLD_LOAD=4.0
MONITOR_INTERVAL=60

# --- Security ---
SSH_PORT=22
ALLOWED_SSH_KEYS=

# --- Backup ---
BACKUP_DIR=/var/backups/syamadmin
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE=0 2 * * *

# --- MySQL ---
MYSQL_ROOT_PASSWORD=auto_generated_on_provision

# --- PHP Version ---
PHP_VERSION=8.3

# --- Logging ---
LOG_FILE=/var/log/syamadmin/agent.log
LOG_LEVEL=INFO

# --- Database ---
DB_PATH=/var/lib/syamadmin/syamadmin.db
# Retention (hari) — pemangkasan data lama otomatis untuk membatasi ukuran DB
METRICS_RETENTION_DAYS=30
AUDIT_RETENTION_DAYS=90
# Memory Core (Pilar 3 & 4)
CHAT_HISTORY_RETENTION_DAYS=14
LONG_TERM_MEMORY_MAX_ROWS=1000
